# === Database ===
POSTGRES_USER=siete
POSTGRES_PASSWORD=siete
POSTGRES_DB=siete_academy
DATABASE_URL=postgresql+psycopg://siete:siete@postgres:5432/siete_academy

# === Redis / Celery ===
REDIS_URL=redis://redis:6379/0

# === Firebase Admin SDK ===
# Full JSON of the service account, serialized as a string.
# Alternatively set FIREBASE_CREDENTIALS_PATH to a file path.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_PATH=/app/credentials/firebase-admin.json
FIREBASE_PROJECT_ID=

# === Frontend Firebase config (public keys, safe for client) ===
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_API_BASE_URL=http://localhost:8000

# === Anthropic (Claude) ===
# Direct SDK, no LangChain/LlamaIndex wrappers. All calls audited in ai_call_logs.
# Not used in Fase 0 (scoring and AI review go in Fase 1); leave blank for piloto.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# === Email (SMTP / Resend / etc.) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Siete Academy <noreply@siete.com>"

# === App ===
APP_ENV=development
APP_SECRET_KEY=change-me
ALLOWED_ORIGINS=http://localhost:5173,https://siete.com
PUBLIC_BASE_URL=http://localhost:5173
